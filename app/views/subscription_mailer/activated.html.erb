<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 600px; margin: 0 auto; background-color: #ffffff; padding: 40px 20px; color: #334155;">
  <div style="text-align: center; margin-bottom: 30px;">
    <h1 style="color: #6D4AFF; font-size: 28px; margin: 0;">CareerAI</h1>
  </div>
  
  <h2 style="color: #0f172a; font-size: 24px; margin-bottom: 20px;">Welcome to Premium, <%= @user.first_name %>! 🎉</h2>
  
  <p style="font-size: 16px; line-height: 1.5; margin-bottom: 24px;">
    Your subscription to <strong>CareerAI <%= @billing_history.plan_name.titleize %></strong> has been successfully activated. You now have access to our suite of advanced features and AI tools.
  </p>
  
  <div style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px; margin-bottom: 24px;">
    <h3 style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #64748b; margin-top: 0; margin-bottom: 16px;">Subscription Details</h3>
    
    <table style="width: 100%; font-size: 15px; border-collapse: collapse;">
      <tr>
        <td style="padding: 8px 0; color: #64748b;">Plan</td>
        <td style="padding: 8px 0; text-align: right; font-weight: 600; color: #0f172a;"><%= @billing_history.plan_name.titleize %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #64748b;">Amount Paid</td>
        <td style="padding: 8px 0; text-align: right; font-weight: 600; color: #0f172a;"><%= @billing_history.currency %> <%= @billing_history.amount %></td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #64748b;">AI Credits Added</td>
        <td style="padding: 8px 0; text-align: right; font-weight: 600; color: #10b981;"><%= @user.monthly_credit_limit %> Credits</td>
      </tr>
      <tr>
        <td style="padding: 8px 0; color: #64748b; border-bottom: none;">Next Renewal Date</td>
        <td style="padding: 8px 0; text-align: right; font-weight: 600; color: #0f172a; border-bottom: none;"><%= @billing_history.renewal_date.strftime('%B %d, %Y') %></td>
      </tr>
    </table>
  </div>
  
  <div style="text-align: center; margin-top: 32px; margin-bottom: 32px;">
    <a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:5173') %>/settings" style="background-color: #6D4AFF; color: #ffffff; text-decoration: none; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; display: inline-block;">View Dashboard</a>
  </div>

  <p style="font-size: 14px; color: #64748b; line-height: 1.5; border-top: 1px solid #e2e8f0; padding-top: 24px;">
    You can download your official invoice at any time from your billing dashboard. If you have any questions, simply reply to this email!
  </p>
</div>
