<div style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; max-width: 600px; margin: 0 auto; background-color: #ffffff; padding: 40px 20px; color: #334155;">
  <div style="text-align: center; margin-bottom: 30px;">
    <h1 style="color: #6D4AFF; font-size: 28px; margin: 0;">CareerAI</h1>
  </div>
  
  <h2 style="color: #0f172a; font-size: 24px; margin-bottom: 20px;">Your AI Credits have arrived! ⚡</h2>
  
  <p style="font-size: 16px; line-height: 1.5; margin-bottom: 24px;">
    Hi <%= @user.first_name %>, your monthly AI credits have been successfully reset. You are fully stocked and ready to supercharge your career tools.
  </p>
  
  <div style="background-color: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 24px; margin-bottom: 24px; text-align: center;">
    <p style="font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #166534; margin-top: 0; margin-bottom: 8px; font-weight: 700;">Current Balance</p>
    <div style="font-size: 42px; font-weight: 900; color: #15803d; line-height: 1;">
      <%= @user.remaining_credits %> <span style="font-size: 18px; font-weight: 600; color: #16a34a;">Credits</span>
    </div>
  </div>
  
  <div style="text-align: center; margin-top: 32px; margin-bottom: 32px;">
    <a href="<%= ENV.fetch('FRONTEND_URL', 'http://localhost:5173') %>/dashboard" style="background-color: #6D4AFF; color: #ffffff; text-decoration: none; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; display: inline-block;">Start Using AI Tools</a>
  </div>
</div>
