# ── Session / Cookie (cross-origin auth) ──
# In production (Vercel → Render), set these in Render env vars:
#   COOKIE_SAME_SITE=none
#   COOKIE_SECURE=true
# For local dev, these defaults work (same_site: lax, secure: false):
# COOKIE_SAME_SITE=lax
# COOKIE_SECURE=false

# ── Frontend (Vite) ──
VITE_API_URL=https://ai-career-platform-kdrr.onrender.com
