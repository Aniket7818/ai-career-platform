# ── Rails ──
RAILS_ENV=development
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379/1

# ── PostgreSQL ──
POSTGRES_DB=ai_career_platform_development
POSTGRES_TEST_DB=ai_career_platform_test
